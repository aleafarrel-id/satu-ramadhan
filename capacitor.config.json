{
  "appId": "com.saturamadhan.mobile",
  "appName": "Satu Ramadhan",
  "webDir": "dist",
  "android": {
    "adjustMarginsForEdgeToEdge": "auto"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 0,
      "launchFadeOutDuration": 0,
      "backgroundColor": "#0a3540",
      "showSpinner": false
    },
    "StatusBar": {
      "overlaysWebView": true,
      "style": "DARK",
      "backgroundColor": "#0a3540"
    },
    "Keyboard": {
      "resize": "native",
      "resizeOnFullScreen": false
    }
  }
}