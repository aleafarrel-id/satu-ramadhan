{
    "index": "081",
    "verse": {
        "verse_1": "Iżasy-syamsu kuwwirat.",
        "verse_2": "Wa iżan-nujūmunkadarat.",
        "verse_3": "Wa iżal-jibālu suyyirat.",
        "verse_4": "Wa iżal-‘isyāru ‘uṭṭilat.",
        "verse_5": "Wa iżal-wuḥūsy ḥusyirat.",
        "verse_6": "Wa iżal-biḥāru sujjirat.",
        "verse_7": "Wa iżan-nufūsu zuwwijat.",
        "verse_8": "Wa iżal-mau'ūdatu su'ilat.",
        "verse_9": "Bi'ayyi żambin qutilat.",
        "verse_10": "Wa iżaṣ-ṣuḥufu nusyirat.",
        "verse_11": "Wa iżas-samā'u kusyiṭat.",
        "verse_12": "Wa iżal-jaḥīmu su‘‘irat.",
        "verse_13": "Wa iżal-jannatu uzlifat.",
        "verse_14": "‘Alimat nafsum mā aḥḍarat.",
        "verse_15": "Falā uqsimu bil-khunnas(i).",
        "verse_16": "Al-jawāril-kunnas(i).",
        "verse_17": "Wal-laili iżā ‘as‘as(a).",
        "verse_18": "Waṣ-ṣubḥi iżā tanaffas(a).",
        "verse_19": "Innahū laqaulu rasūlin karīm(in).",
        "verse_20": "Żī quwwatin ‘inda żil-‘arsyi makīn(in).",
        "verse_21": "Muṭā‘in ṡamma amīn(in).",
        "verse_22": "Wa mā ṣāḥibukum bimajnūn(in).",
        "verse_23": "Wa laqad ra'āhu bil-ufuqil-mubīn(i).",
        "verse_24": "Wa mā huwa ‘alal-gaibi biḍanīn(in).",
        "verse_25": "Wa mā huwa biqauli syaiṭānir rajīm(in).",
        "verse_26": "Fa aina tażhabūn(a).",
        "verse_27": "In huwa illā żikrul lil-‘ālamīn(a).",
        "verse_28": "Liman syā'a minkum ay yastaqīm(a).",
        "verse_29": "Wa mā tasyā'ūna illā ay yasyā'allāhu rabbul-‘ālamīn(a)."
    }
}