{
    "index": "086",
    "verse": {
        "verse_1": "Was-samā'i waṭ-ṭāriq(i).",
        "verse_2": "Wa mā adrāka maṭ-ṭāriq(u).",
        "verse_3": "An-najmuṡ-ṡāqib(u).",
        "verse_4": "In kullu nafsil lammā ‘alaihā ḥāfiẓ(un).",
        "verse_5": "Falyanẓuril-insānu mimma khuliq(a).",
        "verse_6": "Khuliqa mim mā'in dāfiq(in).",
        "verse_7": "Yakhruju mim bainiṣ-ṣulbi wat-tarā'ib(i).",
        "verse_8": "Innahū ‘alā raj‘ihī laqādir(un).",
        "verse_9": "Yauma tublas-sarā'ir(u).",
        "verse_10": "Famā lahū min quwwatiw wa lā nāṣir(in).",
        "verse_11": "Was-samā'i żātir-raj‘(i).",
        "verse_12": "Wal-arḍi żātiṣ-ṣad‘(i).",
        "verse_13": "Innahū laqaulun faṣl(un).",
        "verse_14": "Wa mā huwa bil-hazl(i).",
        "verse_15": "Innahum yakīdūna kaidā(n).",
        "verse_16": "Wa akīdu kaidā(n).",
        "verse_17": "Fa mahhilil-kāfirīna amhilhum ruwaidā(n)."
    }
}