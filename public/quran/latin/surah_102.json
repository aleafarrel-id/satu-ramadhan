{
    "index": "102",
    "verse": {
        "verse_1": "Alhākumut-takāṡur(u). ",
        "verse_2": "Ḥattā zurtumul-maqābir(a).",
        "verse_3": "Kallā saufa ta‘lamūn(a).",
        "verse_4": "Ṡumma kallā saufa ta‘lamūn(a).",
        "verse_5": "Kallā lau ta‘lamūna ‘ilmal-yaqīn(i).",
        "verse_6": "Latarawunnal-jaḥīm(a).",
        "verse_7": "Ṡumma latarawunnahā ‘ainal-yaqīn(i).",
        "verse_8": "Ṡumma latus'alunna yauma'iżin ‘anin-na‘īm(i)."
    }
}