{
    "index": "080",
    "verse": {
        "verse_1": "‘Abasa wa tawallā.",
        "verse_2": "An jā'ahul-a‘mā.",
        "verse_3": "Wa mā yudrīka la‘allahū yazzakkā.",
        "verse_4": "Au yażżakkaru fatanfa‘ahuż-żikrā.",
        "verse_5": "Ammā manistagnā.",
        "verse_6": "Fa anta lahū taṣaddā.",
        "verse_7": "Wa mā ‘alaika allā yazzakkā.",
        "verse_8": "Wa ammā man jā'aka yas‘ā.",
        "verse_9": "Wa huwa yakhsyā.",
        "verse_10": "Fa anta ‘anhu talahhā.",
        "verse_11": "Kallā innahā tażkirah(tun).",
        "verse_12": "Faman syā'a żakarah(ū).",
        "verse_13": "Fī ṣuḥufim mukarrmah(tin).",
        "verse_14": "Marfū‘atim muṭahharah(tin).",
        "verse_15": "Bi'aidī safarah(tin).",
        "verse_16": "Kirāmim bararah(tin).",
        "verse_17": "Qutilal-insānu mā akfarah(ū).",
        "verse_18": "Min ayyi syai'in khalaqah(ū).",
        "verse_19": "Min nuṭfah(tin), khalaqahū fa qaddarah(ū).",
        "verse_20": "Ṡummas-sabīla yassarah(ū).",
        "verse_21": "Ṡumma amātahū fa aqbarah(ū).",
        "verse_22": "Ṡumma iżā syā'a ansyarah(ū).",
        "verse_23": "Kallā lammā yaqḍi mā amarah(ū).",
        "verse_24": "Falyanẓuril-insānu ilā ṭa‘āmih(ī).",
        "verse_25": "Annā ṣababnal-mā'a ṣabbā(n).",
        "verse_26": "Ṡumma syaqaqnal-arḍa syaqqā(n).",
        "verse_27": "Fa'ambatnā fīhā ḥabbā(n).",
        "verse_28": "Wa ‘inabaw wa qaḍbā(n).",
        "verse_29": "Wa zaitūnaw wa nakhlā(n).",
        "verse_30": "Wa ḥadā'iqa gulbā(n).",
        "verse_31": "Wa fākihataw wa abbā(n).",
        "verse_32": "Matā‘al lakum wa li'an‘āmikum.",
        "verse_33": "Fa iżā jā'atiṣ-ṣākhkhah(tu).",
        "verse_34": "Yauma yafirrul-mar'u min akhīh(i).",
        "verse_35": "Wa ummihī wa abīh(i).",
        "verse_36": "Wa ṣāḥibatihī wa banīh(i).",
        "verse_37": "Likullimri'im minhum yauma'iżin sya'nuy yugnīh(i).",
        "verse_38": "Wujūhuy yauma'iżim musfirah(tun).",
        "verse_39": "Ḍāḥikatum mustabsyirah(tun).",
        "verse_40": "Wa wujūhuy yauma'iżin ‘alaihā gabarah(tun).",
        "verse_41": "Tarhaquhā qatarah(tun).",
        "verse_42": "Ulā'ika humul-kafaratul-fajarah(tu)."
    }
}