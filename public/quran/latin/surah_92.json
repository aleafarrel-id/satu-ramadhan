{
    "index": "092",
    "verse": {
        "verse_1": "Wal-laili iżā yagsyā.",
        "verse_2": "Wan-nahāri iżā tajallā.",
        "verse_3": "Wa mā khalaqaż-żakara wal-unṡā.",
        "verse_4": "Inna sa‘yakum lasyattā.",
        "verse_5": "Fa ammā man a‘ṭā wattaqā.",
        "verse_6": "Wa ṣaddaqa bil-ḥusnā.",
        "verse_7": "Fa sanuyassiruhū lil-yusrā.",
        "verse_8": "Wa ammā man bakhila wastagnā.",
        "verse_9": "Wa każżaba bil-ḥusnā.",
        "verse_10": "Fa sanuyassiruhū lil-‘usrā.   ",
        "verse_11": "Wa mā yugnī ‘anhu māluhū iżā taraddā.",
        "verse_12": "Inna ‘alainā lal-hudā.",
        "verse_13": "Wa inna lanā lal-ākhirata wal-ūlā.",
        "verse_14": "Fa anżartukum nāran talaẓẓā.",
        "verse_15": "Lā yaṣlāhā illal-asyqā.",
        "verse_16": "Allażī każżaba wa tawallā.",
        "verse_17": "Wa sayujannabuhal-atqā.",
        "verse_18": "Allażī yu'tī mālahū yatazakkā.",
        "verse_19": "Wa mā li'aḥadin ‘indahū min ni‘matin tujzā.",
        "verse_20": "Illabtigā'a wajhi rabbihil-a‘lā.",
        "verse_21": "Wa lasaufa yarḍā."
    }
}