{
    "index": "088",
    "verse": {
        "verse_1": "Hal atāka ḥadīṡul-gāsyiyah(ti).",
        "verse_2": "Wujūhuy yauma'iżin khāsyi‘ah(tun).",
        "verse_3": "‘Amilatun nāṣibah(tun).",
        "verse_4": "Taṣlā nāran ḥāmiyah(tan).",
        "verse_5": "Tusqā min ‘ainin āniyah(tin).",
        "verse_6": "Laisa lahum ṭa‘āmun illā min ḍarī‘(in).",
        "verse_7": "Lā yusminu wa lā yugnī min jū‘(in).",
        "verse_8": "Wujūhuy yauma'iżin nā‘imah(tun).",
        "verse_9": "Lisa‘yihā rāḍiyah(tun).",
        "verse_10": "Fī jannatin ‘āliyah(tin).",
        "verse_11": "Lā tasama‘u fīhā lāgiyah(tan).",
        "verse_12": "Fīhā ‘ainun jāriyah(tun).",
        "verse_13": "Fīhā sururum marfū‘ah(tun).",
        "verse_14": "Wa akwābum mauḍū‘ah(tun).",
        "verse_15": "Wa namāriqu maṣfūfah(tun).",
        "verse_16": "Wa zarābiyyu mabṡūṡah(tun).",
        "verse_17": "Afalā yanẓurūna ilal-ibili kaifa khuliqat.",
        "verse_18": "Wa ilas-samā'i kaifa rufi‘at.",
        "verse_19": "Wa ilal-jibāli kaifa nuṣibat.",
        "verse_20": "Wa ilal-arḍi kaifa suṭiḥat.",
        "verse_21": "Fa żakkir, innamā anta mużakkir(un).",
        "verse_22": "Lasta ‘alaihim bimusaiṭir(in). ",
        "verse_23": "Illā man tawallā wa kafar(a).",
        "verse_24": "Fa yu‘ażżibuhullāhul-‘ażābal-akbar(a).",
        "verse_25": "Inna ilainā iyābahum.",
        "verse_26": "Ṡumma inna ‘alainā ḥisābahum."
    }
}