{
    "index": "100",
    "verse": {
        "verse_1": "Wal-‘ādiyāti ḍabḥā(n). ",
        "verse_2": "Fal-mūriyāti qadḥā(n).",
        "verse_3": "Fal-mugīrāti ṣubḥā(n).",
        "verse_4": "Fa'aṡarna bihī naq‘ā(n).",
        "verse_5": "Fawasaṭna bihī jam‘ā(n).",
        "verse_6": "Innal-insāna lirabbihī lakanūd(un).",
        "verse_7": "Wa innahū ‘alā żālika lasyahīd(un).",
        "verse_8": "Wa innahū liḥubbil-khairi lasyadīd(un).",
        "verse_9": "Afalā ya‘lamu iżā bu‘ṡira mā fil-qubūr(i).",
        "verse_10": "Wa ḥuṣṣila mā fiṣ-ṣudūr(i).",
        "verse_11": "Inna rabbahum bihim yauma'iżil lakhabīr(un)."
    }
}