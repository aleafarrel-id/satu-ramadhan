{
    "index": "097",
    "verse": {
        "verse_1": "Innā anzalnāhu fī lailatil-qadr(i).",
        "verse_2": "Wa mā adrāka mā lailatul-qadr(i).",
        "verse_3": "Lailatul-qadri khairum min alfi syahr(in).",
        "verse_4": "Tanazzalul-malā'ikatu war rūḥu fīhā bi'iżni rabbihim min kulli amr(in).",
        "verse_5": "Salāmun hiya ḥattā maṭla‘il-fajr(i). "
    }
}