{
    "index": "090",
    "verse": {
        "verse_1": "Lā uqsimu bihāżal-balad(i).",
        "verse_2": "Wa anta ḥillum bihāżal-balad(i).",
        "verse_3": "Wa wālidiw wa mā walad(a).",
        "verse_4": "Laqad khalaqnal-insāna fī kabad(in).",
        "verse_5": "Ayaḥsabu allay yaqdira ‘alaihi  aḥad(un).",
        "verse_6": "Yaqūlu ahlaktu mālal lubadā(n).",
        "verse_7": "Ayaḥsabu allam yarahū aḥad(un).",
        "verse_8": "Alam naj‘al lahū ‘ainain(i).",
        "verse_9": "Wa lisānaw wa syafatain(i).",
        "verse_10": "Wa hadaināhun-najdain(i).",
        "verse_11": "Falaqtaḥamal-‘aqabah(ta).",
        "verse_12": "Wa mā adrāka mal-‘aqabah(tu).",
        "verse_13": "Fakku raqabah(tin).",
        "verse_14": "Au iṭ‘āmun fī yaumin żī masgabah(tin).",
        "verse_15": "Yatīman żā maqrabah(tin).",
        "verse_16": "Au miskīnan żā matrabah(tin).",
        "verse_17": "Ṡumma kāna minal-lażīna āmanū wa tawāṣau biṣ-ṣabri wa tawāṣau bil-marḥamah(ti). ",
        "verse_18": "Ulā'ika aṣḥābul-maimanah(ti).",
        "verse_19": "Wal-lażīna kafarū bi'āyātinā hum aṣḥābul-masy'amah(ti).",
        "verse_20": "‘Alaihim nārum mu'ṣadah(tun)."
    }
}