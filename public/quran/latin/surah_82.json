{
    "index": "082",
    "verse": {
        "verse_1": "Iżas-samā'unfaṭarat.",
        "verse_2": "Wa iżal-kawākibuntaṡarat.",
        "verse_3": "Wa iżal-biḥāru fujjirat.",
        "verse_4": "Wa iżal-qubūru bu‘ṡirat.",
        "verse_5": "‘Alimat nafsum mā qaddamat wa akhkharat.",
        "verse_6": "Yā ayyuhal-insānu mā garraka birabbikal-karīm(i).",
        "verse_7": "Allażī khalaqaka fa sawwāka fa ‘adalak(a).",
        "verse_8": "Fī ayyi ṣūratim mā syā'a rakkabak(a).",
        "verse_9": "Kallā bal tukażżibūna bid-dīn(i).",
        "verse_10": "Wa inna ‘alaikum laḥāfiẓīn(a).",
        "verse_11": "Kirāman kātibīn(a).",
        "verse_12": "Ya‘lamūna mā taf‘alūn(a).",
        "verse_13": "Innal-abrāra lafī na‘īm(in).",
        "verse_14": "Wa innal-fujjāra lafī jaḥīm(in).",
        "verse_15": "Yaṣlaunahā yaumad-dīn(i).",
        "verse_16": "Wa mā hum ‘anhā bigā'ibīn(a). ",
        "verse_17": "Wa mā adrāka mā yaumud-dīn(i).",
        "verse_18": "Ṡumma mā adrāka mā yaumud-dīn(i).",
        "verse_19": "Yauma lā tamliku nafsul linafsin syai'ā(n), wal-amru yauma'iżil lillāh(i)."
    }
}