{
    "index": "087",
    "verse": {
        "verse_1": "Sabbiḥisma rabbikal-a‘lā.",
        "verse_2": "Allażī khalaqa fasawwā.",
        "verse_3": "Wal-lażī qaddara fahadā.",
        "verse_4": "Wal-lażī akhrajal-mar‘ā.",
        "verse_5": "Fa ja‘alahū guṡā'an aḥwā.",
        "verse_6": "Sanuqri'uka falā tansā.",
        "verse_7": "Illā mā syā'allāh(u), innahū ya‘lamul-jahra wa mā yakhfā.",
        "verse_8": "Wa nuyassiruka lil-yusrā.",
        "verse_9": "Fa żakkir in nafa‘atiż-żikrā.",
        "verse_10": "Sayażżakkaru may yakhsyā.",
        "verse_11": "Wa yatajannabuhal-asyqā.",
        "verse_12": "Allażī yaṣlan-nāral-kubrā.",
        "verse_13": "Ṡumma lā yamūtu fīhā wa lā yaḥyā.",
        "verse_14": "Qad aflaḥa man tazakkā.",
        "verse_15": "Wa żakarasma rabbihī fa ṣallā.",
        "verse_16": "Bal tu'ṡirūnal-ḥayātad-dun-yā.",
        "verse_17": "Wal-ākhiratu khairuw wa abqā.",
        "verse_18": "Inna hāżā lafiṣ-ṣuḥufil-ūlā.",
        "verse_19": "Ṣuḥufi ibrāhīma wa mūsā."
    }
}