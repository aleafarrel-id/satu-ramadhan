{
    "index": "055",
    "verse": {
        "verse_1": "Ar-raḥmān(u).",
        "verse_2": "‘Allamal-qur'ān(a).",
        "verse_3": "Khalaqal-insān(a).",
        "verse_4": "‘Allamahul-bayān(a).",
        "verse_5": "Asy-syamsu wal-qamaru biḥusbān(in).",
        "verse_6": "Wan-najmu wasy-syajaru yasjudān(i).",
        "verse_7": "Was-samā'a rafa‘ahā wa waḍa‘al-mīzān(a).",
        "verse_8": "Allā taṭgau fil-mīzān(i).",
        "verse_9": "Wa aqīmul-wazna  bil-qisṭi wa lā tukhsirul-mīzān(a).",
        "verse_10": "Wal-arḍa waḍa‘ahā lil-anām(i). ",
        "verse_11": "Fīhā fākihatuw wan-nakhlu żātul-akmām(i).",
        "verse_12": "Wal-ḥabbu żul-‘aṣfi war-raiḥān(u).",
        "verse_13": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_14": "Khalaqal-insāna min ṣalṣālin kal-fakhkhār(i).",
        "verse_15": "Wa khalaqal-jānna mim mārijim min nār(in).",
        "verse_16": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_17": "Rabbul-masyriqaini wa rabbul-magribain(i).",
        "verse_18": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_19": "Marajal-baḥraini yaltaqiyān(i).",
        "verse_20": "Bainahumā barzakhul lā yabgiyān(i).",
        "verse_21": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_22": "Yakhruju minhumal-lu'lu'u wal-marjān(u).",
        "verse_23": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_24": "Wa lahul-jawāril-munsya'ātu fil-baḥri kal-a‘lām(i).",
        "verse_25": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_26": "Kullu man ‘alaihā fān(in).",
        "verse_27": "Wa yabqā wajhu rabbika żul-jalāli wal-ikrām(i).",
        "verse_28": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_29": "Yas'aluhū man fis-samāwāti wal-arḍ(i), kulla yaumin huwa fī sya'n(in).",
        "verse_30": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_31": "Sanafrugu lakum ayyuhaṡ-ṡaqalān(i).",
        "verse_32": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_33": "Yā ma‘syaral-jinni wal-insi inistaṭa‘tum an tanfużū min aqṭāris-samāwāti wal-arḍi fanfużū, lā tanfużūna illā bisulṭān(in).",
        "verse_34": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_35": "Yursalu ‘alaikumā syuwāẓum min nār(in), wa nuḥāsun falā tantaṣirān(i).",
        "verse_36": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_37": "Fa iżansyaqqatis-samā'u fa kānat wardatan kad-dihān(i).",
        "verse_38": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_39": "Fa yauma'iżil lā yus'alu ‘an żambihī insuw wa lā jānn(un).",
        "verse_40": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_41": "Yu‘raful-mujrimūna bisīmāhum fa yu'khażu bin-nawāṣī wal-aqdām(i).",
        "verse_42": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_43": "Hāżihī jahannamul-latī yukażżibu bihal-mujrimūn(a).",
        "verse_44": "Yaṭūfūna bainahā wa baina ḥamīmin ān(in).",
        "verse_45": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_46": "Wa liman khāfa maqāma rabbihī jannatān(i).",
        "verse_47": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_48": "Żawātā afnān(in).",
        "verse_49": "Fabi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_50": "Fīhimā ‘aināni tajriyān(i).",
        "verse_51": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_52": "Fīhimā min kulli fākihatin zaujān(i).",
        "verse_53": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_54": "Muttaki'īna ‘alā furusyim baṭā'inuhā min istabraq(in), wa janal-jannataini  dān(in).",
        "verse_55": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_56": "Fīhinna qāṣirātuṭ-ṭarf(i), lam yaṭmiṡhunna insun qablahum wa lā jānn(un).",
        "verse_57": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_58": "Ka'annahunnal-yāqūtu wal-marjān(u).",
        "verse_59": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_60": "Hal jazā'ul-iḥsāni illal-iḥsān(u).",
        "verse_61": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_62": "Wa min dūnihimā jannatān(i).",
        "verse_63": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_64": "Mudhāmmatān(i).",
        "verse_65": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_66": "Fīhimā ‘aināni naḍḍākhatān(i).",
        "verse_67": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_68": "Fīhimā fākihatuw wa nakhluw wa rummān(un).",
        "verse_69": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_70": "Fīhinna khairātun ḥisān(un).",
        "verse_71": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_72": "Ḥūrum maqṣūrātun fil-khiyām(i).",
        "verse_73": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_74": "Lam yaṭmiṡhunna insun qablahum wa lā jānn(un).",
        "verse_75": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_76": "Muttaki'īna ‘alā rafrafin khuḍriw wa ‘abqariyyin ḥisān(in).",
        "verse_77": "Fa bi'ayyi ālā'i rabbikumā tukażżibān(i).",
        "verse_78": "Tabārakasmu rabbika żil-jalāli wal-ikrām(i)."
    }
}