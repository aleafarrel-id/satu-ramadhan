{
    "index": "101",
    "verse": {
        "verse_1": "Al-qāri‘ah(tu).",
        "verse_2": "Mal-qāri‘ah(tu).",
        "verse_3": "Wa mā adrāka mal-qāri‘ah(tu).",
        "verse_4": "Yauma yakūnun-nāsu kal-farāsyil-mabṡūṡ(i).",
        "verse_5": "Wa takūnul-jibālu kal-‘ihnil-manfūsy(i).",
        "verse_6": "Fa ammā man ṡaqulat mawāzīnuh(ū).",
        "verse_7": "Fa huwa fī ‘īsyatir rāḍiyah(tin).",
        "verse_8": "Wa ammā man khaffat mawāzīnuh(ū).",
        "verse_9": "Fa ummuhū hāwiyah(tun).",
        "verse_10": "Wa mā adrāka mā hiyah.",
        "verse_11": "Nārun ḥāmiyah(tun)."
    }
}