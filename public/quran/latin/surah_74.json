{
    "index": "074",
    "verse": {
        "verse_1": "Yā ayyuhal-muddaṡṡir(u).",
        "verse_2": "Qum fa'anżir.",
        "verse_3": "Wa rabbaka fakabbir.",
        "verse_4": "Wa ṡiyābaka faṭahhir.",
        "verse_5": "War-rujza fahjur.",
        "verse_6": "Wa lā tamnun tastakṡir(u).",
        "verse_7": "Wa lirabbika faṣbir.",
        "verse_8": "Fa iżā nuqira fin-nāqūr(i).",
        "verse_9": "Fa żālika yauma'iżiy yaumun ‘asīr(un).",
        "verse_10": "‘Alal-kāfirīna gairu yasīr(in).",
        "verse_11": "Żarnī wa man khalaqtu waḥīdā(n).",
        "verse_12": "Wa ja‘altu lahū mālam mamdūdā(n).",
        "verse_13": "Wa banīna syuhūdā(n).",
        "verse_14": "Wa mahhattu lahū tamhīdā(n).",
        "verse_15": "Ṡumma yaṭma‘u an azīd(a).",
        "verse_16": "Kallā, innahū kāna li'āyātinā ‘anīdā(n).",
        "verse_17": "Sa'urhiquhū ṣa‘ūdā(n).",
        "verse_18": "Innahū fakkara wa qaddar(a).",
        "verse_19": "Faqutila kaifa qaddar(a).",
        "verse_20": "Ṡumma qutila kaifa qaddar(a).",
        "verse_21": "Ṡumma naẓar(a).",
        "verse_22": "Ṡumma ‘abasa wa basar(a).",
        "verse_23": "Ṡumma adbara wastakbar(a).",
        "verse_24": "Faqāla in hāżā illā siḥruy yu'ṡar(u).",
        "verse_25": "In hāżā illā qaulul-basyar(i).",
        "verse_26": "Sa'uṣlīhi saqar(a).",
        "verse_27": "Wa mā adrāka mā saqar(a).",
        "verse_28": "Lā tubqī wa lā tażar(u).",
        "verse_29": "Lawwāḥatul lil-basyar(i).",
        "verse_30": "‘Alaihā tis‘ata ‘asyar(a).",
        "verse_31": "Wa mā ja‘alnā aṣḥāban-nāri illā malā'ikah(tan), wa mā ja‘alnā ‘iddatahum illā fitnatal lil-lażīna kafarū, liyastaiqinal-lażīna ūtul-kitāba wa yazdādal-lażīna āmanū īmānaw wa lā yartābal-lażīna ūtul-kitāba wal-mu'minūn(a), wa liyaqūlal-lażīna fī qulūbihim maraḍuw wal-kāfirūna māżā arādallāhu bihāżā maṡalā(n), każālika yuḍillullāhu may yasyā'u wa yahdī may yasyā'(u), wa mā ya‘lamu junūda rabbika illā huw(a), wa mā hiya illā żikrā lil-basyar(i).",
        "verse_32": "Kallā wal-qamar(i).",
        "verse_33": "Wal-laili iż adbar(a).",
        "verse_34": "Waṣ-ṣubḥi iżā asfar(a).",
        "verse_35": "Innahā la'iḥdal-kubar(i).",
        "verse_36": "Nażīral lil-basyar(i).",
        "verse_37": "Liman syā'a minkum ay yataqaddama au yata'akhkhar(a).",
        "verse_38": "Kullu nafsim bimā kasabat rahīnah(tun).",
        "verse_39": "Illā aṣḥābal-yamīn(i).",
        "verse_40": "Fī jannātin - yatasā'alūn(a).",
        "verse_41": "‘Anil-mujrimīn(a).",
        "verse_42": "Mā salakakum fī saqar(a).",
        "verse_43": "Qālū lam naku minal-muṣallīn(a).",
        "verse_44": "Wa lam naku nuṭ‘imul-miskīn(a).",
        "verse_45": "Wa kunnā nakhūḍu ma‘al-khā'iḍīn(a).",
        "verse_46": "Wa kunnā nukażżibu biyaumid-dīn(i).",
        "verse_47": "Ḥattā atānal-yaqīn(u).",
        "verse_48": "Famā tanfa‘uhum syafā‘atusy-syāfi‘īn(a).",
        "verse_49": "Famā lahum ‘anit-tażkirati mu‘riḍīn(a).",
        "verse_50": "Ka'annahum ḥumurum mustanfirah(tun).",
        "verse_51": "Farrat min qaswarah(tin).",
        "verse_52": "Bal yurīdu kullumri'im minhum ay yu'tā ṣuḥufam munasysyarah(tan).",
        "verse_53": "Kallā, bal lā yakhāfūnal-ākhirah(ta).",
        "verse_54": "Kallā innahū tażkirah(tun).",
        "verse_55": "Faman syā'a żakarah(ū).",
        "verse_56": "Wa mā yażkurūna illā ay yasyā'allāh(u), huwa ahlut-taqwā wa ahlul-magfirah(ti)."
    }
}