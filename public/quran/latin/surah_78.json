{
    "index": "078",
    "verse": {
        "verse_1": "‘Amma yatasā'alūn(a).",
        "verse_2": "‘Anin naba'il-‘aẓīm(i).",
        "verse_3": "Allażī hum fīhi mukhtalifūn(a).",
        "verse_4": "Kallā saya‘lamūn(a).",
        "verse_5": "Ṡumma kallā saya‘lamūn(a).",
        "verse_6": "Alam naj‘alil-arḍa mihādā(n).",
        "verse_7": "Wal-jibāla autādā(n).",
        "verse_8": "Wa khalaqnākum azwājā(n).",
        "verse_9": "Wa ja‘alnā naumakum subātā(n).",
        "verse_10": "Wa ja‘alnal-laila libāsā(n).",
        "verse_11": "Wa ja‘alnan-nahāra ma‘āsyā(n).",
        "verse_12": "Wa banainā fauqakum sab‘an syidādā(n).",
        "verse_13": "Wa ja‘alnā sirājaw wahhājā(n).",
        "verse_14": "Wa anzalnā minal-mu‘ṣirāti mā'an ṡajjājā(n).",
        "verse_15": "Linukhrija bihī ḥabbaw wa nabātā(n).",
        "verse_16": "Wa jannātin alfāfā(n).",
        "verse_17": "Inna yaumal-faṣli kāna mīqātā(n).",
        "verse_18": "Yauma yunfakhu fiṣ-ṣūri fa ta'tūna afwājā(n).",
        "verse_19": "Wa futiḥatis-samā'u fa kānat abwābā(n).",
        "verse_20": "Wa suyyiratil-jibālu fa kānat sarābā(n).",
        "verse_21": "Inna jahannama kānat mirṣādā(n).",
        "verse_22": "Liṭ-ṭāgīna ma'ābā(n).",
        "verse_23": "Lābiṡīna fīhā aḥqābā(n).",
        "verse_24": "Lā yażūqūna fīhā bardaw wa lā syarābā(n).",
        "verse_25": "Illā ḥamīmaw wa gassāqā(n).",
        "verse_26": "Jazā'aw wifāqā(n).",
        "verse_27": "Innahum kānū lā yarjūna ḥisābā(n).",
        "verse_28": "Wa każżabū bi'āyātinā kiżżābā(n).",
        "verse_29": "Wa kulla syai'in aḥṣaināhu kitābā(n).",
        "verse_30": "Fa żūqū falan nazīdakum illā ‘ażābā(n)",
        "verse_31": "Inna lil-muttaqīna mafāzā(n).",
        "verse_32": "Ḥadā'iqa wa a‘nābā(n).",
        "verse_33": "Wa kawā‘iba atrābā(n).",
        "verse_34": "Wa ka'san dihāqā(n).",
        "verse_35": "Lā yasma‘ūna fīhā lagwaw wa lā kiżżābā(n).",
        "verse_36": "Jazā'am mir rabbika ‘aṭā'an ḥisābā(n).",
        "verse_37": "Rabbis-samāwāti wal-arḍi wa mā bainahumar-raḥmāni lā yamlikūna minhu khiṭābā(n).",
        "verse_38": "Yauma yaqūmur-rūḥu wal-malā'ikatu ṣaffā(n), lā yatakallamūna illā man ażina lahur-raḥmānu wa qāla ṣawābā(n).",
        "verse_39": "Żālikal-yaumul-ḥaqq(u), faman syā'attakhaża ilā rabbihī ma'ābā(n).",
        "verse_40": "Innā anżarnākum ‘ażāban qarībā(n), yauma yanẓurul-mar'u mā qaddamat yadāhu wa yaqūlul-kāfiru yā laitanī kuntu turābā(n)."
    }
}