{
    "index": "094",
    "verse": {
        "verse_1": "Alam nasyraḥ laka ṣadrak(a).",
        "verse_2": "Wa waḍa‘nā ‘anka wizrak(a).",
        "verse_3": "Allażī anqaḍa ẓahrak(a).",
        "verse_4": "Wa rafa‘nā laka żikrak(a).",
        "verse_5": "Fa'inna ma‘al-‘usri yusrā(n).",
        "verse_6": "Inna ma‘al-‘usri yusrā(n).",
        "verse_7": "Fa iżā faragta fanṣab.",
        "verse_8": "Wa ilā rabbika fargab."
    }
}