{
    "index": "079",
    "verse": {
        "verse_1": "Wan-nāzi‘āti garqā(n).",
        "verse_2": "Wan-nāsyiṭāti nasyṭā(n).",
        "verse_3": "Was-sābiḥāti sabḥā(n).",
        "verse_4": "Fas-sābiqāti sabqā(n).",
        "verse_5": "Fal-mudabbirāti amrā(n).",
        "verse_6": "Yauma tarjufur-rājifah(tu).",
        "verse_7": "Tatba‘uhar-rādifah(tu).",
        "verse_8": "Qulūbuy yauma'iżiw wājifah(tun).",
        "verse_9": "Abṣāruhā khāsyi‘ah(tun).",
        "verse_10": "Yaqūlūna a'innā lamardūdūna fil-ḥāfirah(ti).",
        "verse_11": "A'iżā kunnā ‘iẓāman nakhirah(tan).",
        "verse_12": "Qālū tilka iżan karratun khāsirah(tun).",
        "verse_13": "Fa innamā hiya zajratuw wāḥidah(tun).",
        "verse_14": "Fa iżā hum bis-sāhirah(ti).",
        "verse_15": "Hal atāka ḥadīṡu mūsā.",
        "verse_16": "Iż nādāhu rabbuhū bil-wādil-muqaddasi ṭuwā(n).",
        "verse_17": "Iżhab ilā fir‘auna innahū ṭagā.",
        "verse_18": "Fa qul hal laka ilā an tazakkā.",
        "verse_19": "Wa ahdiyaka ilā rabbika fa takhsyā.",
        "verse_20": "Fa arāhul-āyatal-kubrā.",
        "verse_21": "Fa każżaba wa ‘aṣā.",
        "verse_22": "Ṡumma adbara yas‘ā.",
        "verse_23": "Fa ḥasyara fanādā.",
        "verse_24": "Fa qāla ana rabbukumul-a‘lā.",
        "verse_25": "Fa akhażahullāhu nakālal-ākhirati wal-ūlā.",
        "verse_26": "Inna fī żālika la‘ibratal limay yakhsyā.",
        "verse_27": "A'antum asyaddu khalqan amis-samā'u banāhā.",
        "verse_28": "Rafa‘a samkahā fa sawwāhā.",
        "verse_29": "Wa agṭasya lailahā wa akhraja ḍuḥāhā.",
        "verse_30": "Wal-arḍa ba‘da żālika daḥāhā.",
        "verse_31": "Akhraja minhā mā'ahā wa mar‘āhā.",
        "verse_32": "Wal-jibāla arsāhā.",
        "verse_33": "Matā‘al lakum wa li'an‘āmikum.",
        "verse_34": "Fa iżā jā'atiṭ-ṭāmmatul-kubrā.",
        "verse_35": "Yauma yatażakkarul-insānu mā sa‘ā.",
        "verse_36": "Wa burrizatil-jaḥīmu limay yarā.",
        "verse_37": "Fa ammā man ṭagā.",
        "verse_38": "Wa āṡaral-ḥayātad-dun-yā.",
        "verse_39": "Fa innal-jaḥīma hiyal-ma'wā.",
        "verse_40": "Wa ammā man khāfa maqāma rabbihī wa nahan-nafsa ‘anil-hawā.",
        "verse_41": "Fa innal-jannata hiyal-ma'wā.",
        "verse_42": "Yas'alūnaka ‘anis-sā‘ati ayyāna mursāhā.",
        "verse_43": "Fīma anta min żikrāhā.",
        "verse_44": "Ilā rabbika muntahāhā.",
        "verse_45": "Innamā anta munżiru may yakhsyāhā.",
        "verse_46": "Ka'annahum yauma yaraunahā lam yalbaṡū illā ‘asyiyyatan au ḍuḥāhā."
    }
}