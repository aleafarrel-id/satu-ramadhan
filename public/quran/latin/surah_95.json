{
    "index": "095",
    "verse": {
        "verse_1": "Wat-tīni waz-zaitūn(i).",
        "verse_2": "Wa ṭūri sīnīn(a).",
        "verse_3": "Wa hāżal-baladil-amīn(i).",
        "verse_4": "Laqad khalaqnal-insāna fī aḥsani taqwīm(in).",
        "verse_5": "Ṡumma radadnāhu asfala sāfilīn(a).",
        "verse_6": "Illal-lażīna āmanū wa ‘amiluṣ-ṣāliḥāti falahum ajrun gairu mamnūn(in).",
        "verse_7": "Famā yukażżibuka ba‘du bid-dīn(i).",
        "verse_8": "Alaisallāhu bi'aḥkamil-ḥākimīn(a)."
    }
}