{
    "index": "056",
    "verse": {
        "verse_1": "Iżā waqa‘atil-wāqi‘ah(tu).",
        "verse_2": "Laisa liwaq‘atihā kāżibah(tun).",
        "verse_3": "Khāfiḍatur rāfi‘ah(tun).",
        "verse_4": "Iżā rujjatil-arḍu rajjā(n).",
        "verse_5": "Wa bussatil-jibālu bassā(n).",
        "verse_6": "Fa kānat habā'am mumbaṡṡā(n).",
        "verse_7": "Wa kuntum azwājan ṡalāṡah(tan).",
        "verse_8": "Fa aṣḥābul-maimanah(ti), mā aṣḥābul-maimanah(ti).",
        "verse_9": "Wa aṣḥābul-masy'amah(ti), mā aṣḥābul-masy'amah(ti).",
        "verse_10": "Was-sābiqūnas-sābiqūn(a).",
        "verse_11": "Ulā'ikal-muqarrabūn(a).",
        "verse_12": "Fī jannātin-na‘īm(i).",
        "verse_13": "Ṡullatum minal-awwalīn(a).",
        "verse_14": "Wa qalīlum minal-ākhirīn(a).",
        "verse_15": "‘Alā sururim mauḍūnah(tin).",
        "verse_16": "Muttaki'īna ‘alaihā mutaqābilīn(a).",
        "verse_17": "Yaṭūfu ‘alaihim wildānum mukhalladūn(a).",
        "verse_18": "Bi'akwābiw wa abārīq(a), wa ka'sim mim ma‘īn(in).",
        "verse_19": "Lā yuṣadda‘ūna ‘anhā wa lā yunzifūn(a).",
        "verse_20": "Wa fākihatim mimmā yatakhayyarūn(a).",
        "verse_21": "Wa laḥmi ṭairim mimmā yasytahūn(a).",
        "verse_22": "Wa ḥūrun ‘īn(un).",
        "verse_23": "Ka'amṡālil-lu'lu'il-maknūn(i).",
        "verse_24": "Jazā'am bimā kānū ya‘malūn(a).",
        "verse_25": "Lā yasma‘ūna fīhā lagwaw wa lā ta'ṡīmā(n).",
        "verse_26": "Illā qīlan salāman salāmā(n).",
        "verse_27": "Wa aṣḥābul-yamīn(i), mā aṣḥābul-yamīn(i).",
        "verse_28": "Fī sidrim makhḍūd(in).",
        "verse_29": "Wa ṭalḥim manḍūd(in).",
        "verse_30": "Wa ẓillim mamdūd(in).",
        "verse_31": "Wa mā'im maskūb(in).",
        "verse_32": "Wa fākihatin kaṡīrah(tin).",
        "verse_33": "Lā maqṭū‘atiw wa lā mamnū‘ah(tin).",
        "verse_34": "Wa furusyim marfū‘ah(tin).",
        "verse_35": "Innā ansya'nāhunna insyā'ā(n).",
        "verse_36": "Faja‘alnāhunna abkārā(n).",
        "verse_37": "‘Uruban atrābā(n).",
        "verse_38": "Li'aṣḥābil-yamīn(i).",
        "verse_39": "Ṡullatum minal-awwalīn(a).",
        "verse_40": "Wa ṡullatum minal-ākhirīn(a).",
        "verse_41": "Wa aṣḥābusy-syimāl(i), mā aṣḥābusy-syimāl(i).",
        "verse_42": "Fī samūmiw wa ḥamīm(in).",
        "verse_43": "Wa ẓillim miy yaḥmūm(in).",
        "verse_44": "Lā bāridiw wa lā karīm(in).",
        "verse_45": "Innahum kānū qabla żālika mutrafīn(a).",
        "verse_46": "Wa kānū yuṣirrūna ‘alal-ḥinṡil-‘aẓīm(i).",
        "verse_47": "Wa kānū yaqūlūn(a), a'iżā mitnā  wa kunnā turābaw wa ‘iẓāman a'innā lamab‘ūṡūn(a). ",
        "verse_48": "Awa'ābā'unal-awwalūn(a).",
        "verse_49": "Qul innal-awwalīna wal-ākhirīn(a).",
        "verse_50": "Lamajmū‘ūn(a), ilā mīqāti yaumim ma‘lūm(in).",
        "verse_51": "Ṡumma innakum ayyuhaḍ-ḍāllūnal-mukażżibūn(a).",
        "verse_52": "La'ākilūna min syajarim min zaqqūm(in).",
        "verse_53": "Fa māli'ūna minhal-buṭūn(a).",
        "verse_54": "Fasyāribūna ‘alaihi minal-ḥamīm(i).",
        "verse_55": "Fa syāribūna syurbal-hīm(i).",
        "verse_56": "Hāżā nuzuluhum yaumad-dīn(i).",
        "verse_57": "Naḥnu khalaqnākum falau lā tuṣaddiqūn(a).",
        "verse_58": "Afa ra'aitum mā tumnūn(a).",
        "verse_59": "A'antum takhluqūnahū am naḥnul-khāliqūn(a).",
        "verse_60": "Naḥnu qaddarnā bainakumul-mauta wa mā naḥnu bimasbūqīn(a).",
        "verse_61": "‘Alā an nubaddila amṡālakum wa nunsyi'akum fī mā lā ta‘lamūn(a).",
        "verse_62": "Wa laqad ‘alimtumun-nasy'atal-ūlā falau lā tażakkarūn(a).",
        "verse_63": "Afara'aitum mā taḥruṡūn(a).",
        "verse_64": "A'antum tazra‘ūnahū am naḥnuz-zāri‘ūn(a).",
        "verse_65": "Lau nasyā'u laja‘alnāhu ḥuṭāman fa ẓaltum tafakkahūn(a).",
        "verse_66": "Innā lamugramūn(a).",
        "verse_67": "Bal naḥnu maḥrūmūn(a).",
        "verse_68": "Afa ra'aitumul-mā'al-lażī tasyrabūn(a).",
        "verse_69": "A'antum anzaltumūhu minal-muzni am naḥnul-munzilūn(a).",
        "verse_70": "Lau nasyā'u ja‘alnāhu ujājan falau lā tasykurūn(a).",
        "verse_71": "Afa ra'aitumun-nāral-latī tūrūn(a).",
        "verse_72": "A'antum ansya'tum syajaratahā am naḥnul-munsyi'ūn(a).",
        "verse_73": "Naḥnu ja‘alnāhā tażkirataw wa matā‘al lil-muqwīn(a).",
        "verse_74": "Fa sabbiḥ bismi rabbikal-‘aẓīm(i).",
        "verse_75": "Falā uqsimu bimawāqi‘in-nujūm(i).",
        "verse_76": "Wa innahū laqasamul lau ta‘lamūna ‘aẓīm(un).",
        "verse_77": "Innahū laqur'ānun karīm(un).",
        "verse_78": "Fī kitābim maknūn(in).",
        "verse_79": "Lā yamassuhū illal-muṭahharūn(a).",
        "verse_80": "Tanzīlum mir rabbil-‘ālamīn(a).",
        "verse_81": "Afa biḥāżal-ḥadīṡi  antum mudhinūn(a).",
        "verse_82": "Wa taj‘alūna rizqakum annakum tukażżibūn(a).",
        "verse_83": "Falau lā iżā balagatil-ḥulqūm(a).",
        "verse_84": "Wa antum ḥīna'iżin tanẓurūn(a).",
        "verse_85": "Wa naḥnu aqrabu ilaihi minkum wa lākil lā tubṣirūn(a).",
        "verse_86": "Falau lā in kuntum gaira madīnīn(a).",
        "verse_87": "Tarji‘ūnahā in kuntum ṣādiqīn(a).",
        "verse_88": "Fa ammā in kāna minal-muqarrabīn(a).",
        "verse_89": "Fa rauḥuw wa raiḥān(un), wa jannatu na‘īm(in).",
        "verse_90": "Wa ammā in kāna min aṣḥābil-yamīn(i).",
        "verse_91": "Fa salāmul laka min aṣḥābil-yamīn(i).",
        "verse_92": "Wa ammā in kāna minal-mukażżibīnaḍ-ḍāllīn(a).",
        "verse_93": "Fa nuzulum min ḥamīm(in). ",
        "verse_94": "Wa taṣliyatu jaḥīm(in).",
        "verse_95": "Inna hāżā lahuwal-ḥaqqul-yaqīn(i).",
        "verse_96": "Fa sabbiḥ bismi rabbikal-‘aẓīm(i)."
    }
}