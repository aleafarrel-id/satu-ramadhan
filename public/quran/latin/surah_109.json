{
    "index": "109",
    "verse": {
        "verse_1": "Qul yā ayyuhal-kāfirūn(a).",
        "verse_2": "Lā a‘budu mā ta‘budūn(a).",
        "verse_3": "Wa lā antum ‘ābidūna mā a‘bud(u).",
        "verse_4": "Wa lā ana ‘ābidum mā ‘abattum.",
        "verse_5": "Wa lā antum ‘ābidūna mā a‘bud(u).",
        "verse_6": "Lakum dīnukum wa liya dīn(i)."
    }
}