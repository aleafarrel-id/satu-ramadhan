{
    "index": "107",
    "verse": {
        "verse_1": "Ara'aital-lażī yukażżibu bid-dīn(i).",
        "verse_2": "Fa żālikal-lażī yadu‘‘ul-yatīm(a).",
        "verse_3": "Wa lā yaḥuḍḍu ‘alā ṭa‘āmil-miskīn(i).",
        "verse_4": "Fawailul lil-muṣallīn(a).",
        "verse_5": "Allażīna hum ‘an ṣalātihim sāhūn(a).",
        "verse_6": "Allażīna hum yurā'ūn(a).",
        "verse_7": "Wa yamna‘ūnal-mā‘ūn(a)."
    }
}