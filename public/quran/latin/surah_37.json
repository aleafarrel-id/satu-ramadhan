{
    "index": "037",
    "verse": {
        "verse_1": "Waṣ-ṣāffāti ṣaffā(n).",
        "verse_2": "Faz-zājirāti zajrā(n).",
        "verse_3": "Fat-tāliyāti żikrā(n).",
        "verse_4": "Inna ilāhakum lawāḥid(un).",
        "verse_5": "Rabbus-samāwāti wal-arḍi wa mā bainahumā wa rabbul-masyāriq(i).",
        "verse_6": "Innā zayyannas-samā'ad-dun-yā bizīnatinil-kawākib(i).",
        "verse_7": "Wa ḥifẓam min kulli syaiṭānim mārid(in).",
        "verse_8": "Lā yassammā‘ūna ilal-mala'il-a‘lā wa yuqżafūna min kulli jānib(in).",
        "verse_9": "Duḥūraw wa lahum ‘ażābuw wāṣib(un).",
        "verse_10": "Illā man khaṭifal-khaṭfata fa'atba‘ahū syihābun ṡāqib(un).",
        "verse_11": "Fastaftihim ahum asyaddu khalqan am man khalaqnā, innā khalaqnāhum min ṭīnil lāzib(in).",
        "verse_12": "Bal ‘ajibta wa yaskharūn(a).",
        "verse_13": "Wa iżā żukkirū lā yażkurūn(a).",
        "verse_14": "Wa iżā ra'au āyatay yastaskhirūn(a).",
        "verse_15": "Wa qālū in hāżā illā siḥrum mubīn(un).",
        "verse_16": "A'iżā mitnā wa kunnā turābaw wa ‘iẓāman a'innā lamab‘ūṡūn(a).",
        "verse_17": "Awa ābā'unal-awwalūn(a).",
        "verse_18": "Qul na‘am wa antum dākhirūn(a).",
        "verse_19": "Fa'innamā hiya zajratuw wāḥidatun fa'iżā hum yanẓurūn(a).",
        "verse_20": "Wa qālū yā wailanā hāżā yaumud-dīn(i).",
        "verse_21": "Hāżā yaumul-faṣlil-lażī kuntum bihī tukażżibūn(a).",
        "verse_22": "Uḥsyurul-lażīna ẓalamū wa azwājahum wa mā kānū ya‘budūn(a).",
        "verse_23": "Min dūnillāhi fahdūhum ilā ṣirāṭil-jaḥīm(i).",
        "verse_24": "Waqifūhum innahum mas'ūlūn(a).",
        "verse_25": "Mā lakum lā tanāṣarūn(a).",
        "verse_26": "Bal humul-yauma mustaslimūn(a).",
        "verse_27": "Wa aqbala ba‘ḍuhum ‘alā ba‘ḍiy yatasā'alūn(a).",
        "verse_28": "Qālū innakum kuntum ta'tūnanā ‘anil-yamīn(i).",
        "verse_29": "Qālū bal lam takūnū mu'minīn(a).",
        "verse_30": "Wa mā kāna lanā ‘alaikum min sulṭān(in), bal kuntum qauman ṭāgīn(a).",
        "verse_31": "Fa ḥaqqa ‘alainā qaulu rabbinā, innā lażā'iqūn(a).",
        "verse_32": "Fa agwainākum innā kunnā gāwīn(a).",
        "verse_33": "Fa innahum yauma'iżin fil-‘ażābi musytarikūn(a).",
        "verse_34": "Innā każālika naf‘alu bil-mujrimīn(a).",
        "verse_35": "Innahum kānū iżā qīla lahum lā ilāha illallāhu yastakbirūn(a).",
        "verse_36": "Wa yaqūlūna a'innā latārikū ālihatinā lisyā‘irim majnūn(in).",
        "verse_37": "Bal jā'a bil-ḥaqqi wa ṣaddaqal-mursalīn(a).",
        "verse_38": "Innakum lażā'iqul-‘ażābil-alīm(i).",
        "verse_39": "Wa mā tujzauna illā mā kuntum ta‘malūn(a).",
        "verse_40": "Illā ‘ibādallāhil-mukhlaṣīn(a).",
        "verse_41": "Ulā'ika lahum rizqum ma‘lūm(un).",
        "verse_42": "Fawākihu wa hum mukramūn(a).",
        "verse_43": "Fī jannātin na‘īm(i).",
        "verse_44": "‘Alā sururim mutaqābilīn(a).",
        "verse_45": "Yuṭāfu ‘alaihim bika'sim mim ma‘īn(in).",
        "verse_46": "Baiḍā'a lażżatil lisy-syāribīn(a).",
        "verse_47": "Lā fīhā gauluw wa lā hum ‘anhā yunzafūn(a).",
        "verse_48": "Wa ‘indahum qāṣirātuṭ-ṭarfi ‘īn(un).",
        "verse_49": "Ka'annahum baiḍum maknūn(un).",
        "verse_50": "Fa'aqbala ba‘ḍuhum ‘alā ba‘ḍiy yatasā'alūn(a).",
        "verse_51": "Qāla qā'ilum minhum innī kāna lī qarīn(un).",
        "verse_52": "Yaqūlu a'innaka laminal-muṣaddiqīn(a).",
        "verse_53": "A'iżā mitnā wa kunnā turāban a'innā lamadīnūn(a).",
        "verse_54": "Qāla hal antum muṭṭali‘ūn(a).",
        "verse_55": "Faṭṭala‘a fa ra'āhu fī sawā'il-jaḥīm(i).",
        "verse_56": "Qāla tallāhi in kitta laturdīn(i).",
        "verse_57": "Wa lau lā ni‘matu rabbī lakuntu minal-muḥḍarīn(a).",
        "verse_58": "Afamā naḥnu bimayyitīn(a).",
        "verse_59": "Illā mautatunal-ūlā wa mā naḥnu bimu‘ażżabīn(a).",
        "verse_60": "Inna hāżā lahuwal-fauzul-‘aẓīm(u).",
        "verse_61": "Limiṡli hāżā falya‘malil-‘āmilūn(a).",
        "verse_62": "Ażālika khairun nuzulan am syajaratuz-zaqqūm(i).",
        "verse_63": "Innā ja‘alnāhā fitnatal liẓ-ẓālimīn(a).",
        "verse_64": "Innahā syajaratun takhruju fī aṣlil-jaḥīm(i).",
        "verse_65": "Ṭal‘uhā ka'annahū ru'ūsusy-syayāṭīn(i).",
        "verse_66": "Fa innahum la'ākilūna minhā fa māli'ūna minhal-buṭūn(a).",
        "verse_67": "Ṡumma inna lahum ‘alaihā lasyaubam min ḥamīm(in).",
        "verse_68": "Ṡumma inna marji‘ahum la'ilal-jaḥīm(i).",
        "verse_69": "Innahum alfau ābā'ahum ḍāllīn(a).",
        "verse_70": "Fahum ‘alā āṡārihim yuhra‘ūn(a).",
        "verse_71": "Wa laqad ḍalla qablahum akṡarul-awwalīn(a).",
        "verse_72": "Wa laqad arsalnā fīhim munżirīn(a).",
        "verse_73": "Fanẓur kaifa kāna ‘āqibatul-munżarīn(a).",
        "verse_74": "Illā ‘ibādallāhil-mukhlaṣīn(a).",
        "verse_75": "Wa laqad nādānā nūḥun falani‘mal-mujībūn(a).",
        "verse_76": "Wa najjaināhu wa ahlahū minal-karbil-‘aẓīm(i).",
        "verse_77": "Wa ja‘alnā żurriyyatahū humul-bāqīn(a).",
        "verse_78": "Wa taraknā ‘alaihi fil-ākhirīn(a).",
        "verse_79": "Salāmun ‘alā nūḥin fil-‘ālamīn(a).",
        "verse_80": "Innā każālika najzil-muḥsinīn(a).",
        "verse_81": "Innahū min ‘ibādinal-mu'minīn(a).",
        "verse_82": "Ṡumma agraqnal-ākharīn(a).",
        "verse_83": "Wa inna min syī‘atihī la'ibrāhīm(a).",
        "verse_84": "Iż jā'a rabbahū biqalbin salīm(in).",
        "verse_85": "Iż qāla li'abīhi wa qaumihī māżā ta‘budūn(a).",
        "verse_86": "A'ifkan ālihatan dūnallāhi turīdūn(a).",
        "verse_87": "Famā ẓannukum birabbil-‘ālamīn(a).",
        "verse_88": "Fa naẓara naẓratan fin-nujūm(i).",
        "verse_89": "Fa qāla innī saqīm(un).",
        "verse_90": "Fa tawallau ‘anhu mudbirīn(a).",
        "verse_91": "Farāga ilā ālihatihim faqāla alā ta'kulūn(a).",
        "verse_92": "Mā lakum lā tanṭiqūn(a).",
        "verse_93": "Farāga ‘alaihim ḍarbam bil-yamīn(i).",
        "verse_94": "Fa aqbalū ilaihi yaziffūn(a).",
        "verse_95": "Qāla ata‘budūna mā tanḥitūn(a).",
        "verse_96": "Wallāhu khalaqakum wa mā ta‘malūn(a).",
        "verse_97": "Qālubnū lahū bun-yānan fa'alqūhu fil-jaḥīm(i).",
        "verse_98": "Fa arādū bihī kaidan faja‘alnāhumul-asfalīn(a).",
        "verse_99": "Wa qāla innī żāhibun ilā rabbī sayahdīn(i).",
        "verse_100": "Rabbi hab lī minaṣ-ṣāliḥīn(a).",
        "verse_101": "Fa basysyarnāhu bigulāmin ḥalīm(in).",
        "verse_102": "Falammā balaga ma‘ahus-sa‘ya qāla yā bunayya innī arā fil-manāmi annī ażbaḥuka fanẓur māżā tarā, qāla yā abatif‘al mā tu'mar(u), satajidunī in syā'allāhu minaṣ-ṣābirīn(a).",
        "verse_103": "Falammā aslamā wa tallahū lil-jabīn(i).",
        "verse_104": "Wa nādaināhu ay yā ibrāhīm(u).",
        "verse_105": "Qad ṣaddaqtar-ru'yā, innā każālika najzil-muḥsinīn(a).",
        "verse_106": "Inna hāżā lahuwal-balā'ul-mubīn(u).",
        "verse_107": "Wa fadaināhu biżibḥin ‘aẓīm(in).",
        "verse_108": "Wa taraknā ‘alaihi fil-ākhirīn(a).",
        "verse_109": "Salāmun ‘alā ibrāhīm(a).",
        "verse_110": "Każālika najzil-muḥsinīn(a).",
        "verse_111": "Innahū min ‘ibādinal-mu'minīn(a).",
        "verse_112": "Wa basysyarnāhu bi'isḥāqa nabiyyam minaṣ-ṣāliḥīn(a).",
        "verse_113": "Wa bāraknā ‘alaihi wa ‘alā isḥāq(a), wa min żurriyyatihimā muḥsinuw wa ẓālimul linafsihī mubīn(un).",
        "verse_114": "Wa laqad manannā ‘alā mūsā wa hārūn(a).",
        "verse_115": "Wa najjaināhumā wa qaumahumā minal-karbil-‘aẓīm(i).",
        "verse_116": "Wa naṣarnāhum fakānū humul-gālibīn(a).",
        "verse_117": "Wa ātaināhumal-kitābal-mustabīn(a).",
        "verse_118": "Wa hadaināhumaṣ-ṣirāṭal-mustaqīm(a).",
        "verse_119": "Wa taraknā ‘alaihimā fil-ākhirīn(a).",
        "verse_120": "Salāmun ‘alā mūsā wa hārūn(a).",
        "verse_121": "Innā każālika najzil-muḥsinīn(a).",
        "verse_122": "Innahumā min ‘ibādinal-mu'minīn(a).",
        "verse_123": "Wa inna ilyāsa laminal-mursalīn(a).",
        "verse_124": "Iż qāla liqaumihī alā tattaqūn(a).",
        "verse_125": "Atad‘ūna ba‘law wa tażarūna aḥsanal-khāliqīn(a).",
        "verse_126": "Allāha rabbakum wa rabba ābā'ikumul-awwalīn(a).",
        "verse_127": "Fakażżabūhu fa'innahum lamuḥḍarūn(a).",
        "verse_128": "Illā ‘ibādallāhil-mukhlaṣīn(a).",
        "verse_129": "Wa taraknā ‘alaihi fil-ākhirīn(a).",
        "verse_130": "Salāmun ‘alā ilyāsīn(a).",
        "verse_131": "Innā każālika najzil-muḥsinīn(a).",
        "verse_132": "Innahū min ‘ibādinal-mu'minīn(a).",
        "verse_133": "Wa inna lūṭal laminal-mursalīn(a).",
        "verse_134": "Iż najjaināhu wa ahlahū ajma‘īn(a).",
        "verse_135": "Illā ‘ajūzan fil-gābirīn(a).",
        "verse_136": "Ṡumma dammarnal-ākharīn(a).",
        "verse_137": "Wa innakum latamurrūna ‘alaihim muṣbiḥīn(a).",
        "verse_138": "Wa bil-lail(i), afalā ta‘qilūn(a).",
        "verse_139": "Wa inna yūnusa laminal-mursalīn(a).",
        "verse_140": "Iż abaqa ilal-fulkil-masyḥūn(i).",
        "verse_141": "Fa sāhama fakāna minal-mudḥaḍīn(a).",
        "verse_142": "Faltaqamahul-ḥūtu wa huwa mulīm(un).",
        "verse_143": "Falau lā annahū kāna minal-musabbiḥīn(a).",
        "verse_144": "Lalabiṡa fī baṭnihī ilā yaumi yub‘aṡūn(a).",
        "verse_145": "Fa nabażnāhu bil-‘arā'i wa huwa saqīm(un).",
        "verse_146": "Wa ambatnā ‘alaihi syajaratam miy yaqṭīn(in).",
        "verse_147": "Wa arsalnāhu ilā mi'ati alfin au yazīdūn(a).",
        "verse_148": "Fa'āmanū famatta‘nāhum ilā ḥīn(in).",
        "verse_149": "Fastaftihim alirabbikal-banātu wa lahumul-banūn(a).",
        "verse_150": "Am khalaqnal-malā'ikata ināṡaw wa hum syāhidūn(a).",
        "verse_151": "Alā innahum min ifkihim layaqūlūn(a).",
        "verse_152": "Waladallāh(u), wa innahum lakāżibūn(a).",
        "verse_153": "Aṣṭafal-banāti ‘alal-banīn(a).",
        "verse_154": "Mā lakum, kaifa taḥkumūn(a).",
        "verse_155": "Afalā tażakkarūn(a).",
        "verse_156": "Am lakum sulṭānum mubīn(un).",
        "verse_157": "Fa'tū bikitābikum in kuntum ṣādiqīn(a).",
        "verse_158": "Wa ja‘alū bainahū wa bainal-jinnati nasabā(n), wa laqad ‘alimatil-jinnatu innahum lamuḥḍarūn(a).",
        "verse_159": "Subḥānallāhi ‘ammā yaṣifūn(a).",
        "verse_160": "Illā ‘ibādallāhil-mukhlaṣīn(a).",
        "verse_161": "Fa'innakum wa mā ta‘budūn(a).",
        "verse_162": "Mā antum ‘alaihi bifātinīn(a).",
        "verse_163": "Illā man huwa ṣālil-jaḥīm(i).",
        "verse_164": "Wa mā minnā illā lahū maqāmum ma‘lūm(un).",
        "verse_165": "Wa innā lanaḥnuṣ-ṣāffūn(a).",
        "verse_166": "Wa innā lanaḥnul-musabbiḥūn(a).",
        "verse_167": "Wa in kānū layaqūlūn(a).",
        "verse_168": "Lau anna ‘indanā żikram minal-awwalīn(a).",
        "verse_169": "Lakunnā ‘ibādallāhil-mukhlaṣīn(a).",
        "verse_170": "Fa kafarū bih(ī), fasaufa ya‘lamūn(a).",
        "verse_171": "Wa laqad sabaqat kalimatunā li‘ibādinal-mursalīn(a).",
        "verse_172": "Innahum lahumul-manṣūrūn(a).",
        "verse_173": "Wa inna jundanā lahumul-gālibūn(a).",
        "verse_174": "Fatawalla ‘anhum ḥattā ḥīn(in).",
        "verse_175": "Wa abṣirhum, fa saufa yubṣirūn(a).",
        "verse_176": "Afabi‘ażābinā yasta‘jilūn(a).",
        "verse_177": "Fa iżā nazala bisāḥatihim fa sā'a ṣabāḥul-munżarīn(a).",
        "verse_178": "Wa tawalla ‘anhum ḥattā ḥīn(in).",
        "verse_179": "Wa abṣir, fasaufa yubṣirūn(a).",
        "verse_180": "Subḥāna rabbika rabbil-‘izzati ‘ammā yaṣifūn(a).",
        "verse_181": "Wa salāmun ‘alal-mursalīn(a).",
        "verse_182": "Wal-ḥamdu lillāhi rabbil-‘ālamīn(a)."
    }
}