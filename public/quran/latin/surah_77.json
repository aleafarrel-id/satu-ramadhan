{
    "index": "077",
    "verse": {
        "verse_1": "Wal-mursalāti ‘urfā(n).",
        "verse_2": "Fal-‘āṣifāti ‘aṣfā(n).",
        "verse_3": "Wan-nāsyirāti nasyrā(n).",
        "verse_4": "Fal-fāriqāti farqā(n).",
        "verse_5": "Fal-mulqiyāti żikrā(n).",
        "verse_6": "‘Użran au nużrā(n).",
        "verse_7": "Innamā tū‘adūna lawāqi‘(un).",
        "verse_8": "Fa iżan-nujūmu ṭumisat.",
        "verse_9": "Wa iżas-samā'u furijat.",
        "verse_10": "Wa iżal-jibālu nusifat. ",
        "verse_11": "Wa iżar-rusulu uqqitat.",
        "verse_12": "Li'ayyi yaumin ujjilat.",
        "verse_13": "Liyaumil-faṣl(i).",
        "verse_14": "Wa mā adrāka mā yaumul-faṣl(i).",
        "verse_15": "Wailuy yauma'iżil lil-mukażżibīn(a).",
        "verse_16": "Alam nuhlikil-awwalīn(a).",
        "verse_17": "Ṡumma nutbi‘uhumul-ākhirīn(a).",
        "verse_18": "Każālika naf‘alu bil-mujrimīn(a).",
        "verse_19": "Wailuy yauma'iżil lil-mukażżibīn(a).",
        "verse_20": "Alam nakhluqkum mim mā'im mahīn(in).",
        "verse_21": "Fa ja‘alnāhu fī qarārim makīn(in).",
        "verse_22": "Ilā qadarim ma‘lūm(in).",
        "verse_23": "Fa qadarnā, fani‘mal-qādirūn(a).",
        "verse_24": "Wailuy yauma'iżil lil-mukażżibīn(a).",
        "verse_25": "Alam naj‘alil-arḍa kifātā(n).",
        "verse_26": "Aḥyā'aw wa amwātā(n).",
        "verse_27": "Wa ja‘alnā fīhā rawāsiya syāmikhātiw wa asqainākum mā'an furātā(n).",
        "verse_28": "Wailuy yauma'iżil lil-mukażżibīn(a).",
        "verse_29": "Inṭaliqū ilā mā kuntum bihī tukażżibūn(a).",
        "verse_30": "Inṭaliqū ilā ẓillin żī ṡalāṡi syu‘ab(in).",
        "verse_31": "Lā ẓalīliw wa lā yugnī minal-lahab(i).",
        "verse_32": "Innahā tarmī bisyararin kal-qaṣr(i).",
        "verse_33": "Ka'annahū jimālatun ṣufr(un).",
        "verse_34": "Wailuy yauma'iżil lil-mukażżibīn(a).",
        "verse_35": "Hāżā yaumu lā yanṭiqūn(a).",
        "verse_36": "Wa lā yu'żanu lahum fa ya‘tażirūn(a).",
        "verse_37": "Wailuy yauma'iżil lil-mukażżibīn(a).",
        "verse_38": "Hāżā yaumul-faṣli jama‘nākum wal-awwalīn(a).",
        "verse_39": "Fa'in kāna lakum kaidun fakīdūn(i).",
        "verse_40": "Wailuy yauma'iżil lil-mukażżibīn(a).",
        "verse_41": "Innal-muttaqīna fī ẓilāliw wa ‘uyūn(in).",
        "verse_42": "Wa fawākiha mimmā yasytahūn(a).",
        "verse_43": "Kulū wasyrabū hanī'am bimā kuntum ta‘malūn(a).",
        "verse_44": "Innā każālika najzil-muḥsinīn(a).",
        "verse_45": "Wailuy yauma'iżil lil-mukażżibīn(a).",
        "verse_46": "Kulū wa tamatta‘ū qalīlan innakum mujrimūn(a).",
        "verse_47": "Wailuy yauma'iżil lil-mukażżibīn(a).",
        "verse_48": "Wa iżā qīla lahumurka‘ū lā yarka‘ūn(a).",
        "verse_49": "Wailuy yauma'iżil lil-mukażżibīn(a).",
        "verse_50": "Fa bi'ayyi ḥadīṡim ba‘dahū yu'minūn(a)."
    }
}