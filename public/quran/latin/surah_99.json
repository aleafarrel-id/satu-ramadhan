{
    "index": "099",
    "verse": {
        "verse_1": "Iżā zulzilatil-arḍu zilzālahā.",
        "verse_2": "Wa akhrajatil-arḍu aṡqālahā.",
        "verse_3": "Wa qālal-insānu mā lahā.",
        "verse_4": "Yauma'iżin tuḥaddiṡu akhbārahā.",
        "verse_5": "Bi'anna rabbaka auḥā lahā.",
        "verse_6": "Yauma'iżiy yaṣdurun-nāsu asytātā(n), liyurau a‘mālahum.",
        "verse_7": "Famay ya‘mal miṡqāla żarratin khairay yarah(ū).",
        "verse_8": "Wa may ya‘mal miṡqāla żarratin syarray yarah(ū)."
    }
}