{
    "index": "001",
    "verse": {
        "verse_1": "Bismillāhir-raḥmānir-raḥīm(i). ",
        "verse_2": "Al-ḥamdu lillāhi rabbil-‘ālamīn(a). ",
        "verse_3": "Ar-raḥmānir-raḥīm(i). ",
        "verse_4": "Māliki yaumid-dīn(i). ",
        "verse_5": "Iyyāka na‘budu wa iyyāka nasta‘īn(u), ",
        "verse_6": "Ihdinaṣ-ṣirāṭal-mustaqīm(a). ",
        "verse_7": "Ṣirāṭal-lażīna an‘amta ‘alaihim, gairil-magḍūbi ‘alaihim wa laḍ-ḍāllīn(a). "
    }
}