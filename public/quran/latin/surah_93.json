{
    "index": "093",
    "verse": {
        "verse_1": "Waḍ-ḍuḥā.",
        "verse_2": "Wal-laili iżā sajā.",
        "verse_3": "Mā wadda‘aka rabbuka wa mā qalā.",
        "verse_4": "Wa lal-ākhiratu khairul laka minal-ūlā.",
        "verse_5": "Wa lasaufa yu‘ṭīka rabbuka fa tarḍā.",
        "verse_6": "Alam yajidka yatīman fa āwā.",
        "verse_7": "Wa wajadaka ḍāllan fa hadā.",
        "verse_8": "Wa wajadaka ‘ā'ilan fa agnā.",
        "verse_9": "Fa ammal-yatīma falā taqhar.",
        "verse_10": "Wa ammas-sā'ila falā tanhar.",
        "verse_11": "Wa ammā bini‘mati rabbika fa ḥaddiṡ."
    }
}