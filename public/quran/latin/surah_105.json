{
    "index": "105",
    "verse": {
        "verse_1": "Alam tara kaifa fa‘ala rabbuka bi'aṣḥābil-fīl(i).",
        "verse_2": "Alam yaj‘al kaidahum fī taḍlīl(in).",
        "verse_3": "Wa arsala ‘alaihim ṭairan abābīl(a).",
        "verse_4": "Tarmīhim biḥijāratim min sijjīl(in).",
        "verse_5": "Fa ja‘alahum ka‘aṣfim ma'kūl(in)."
    }
}