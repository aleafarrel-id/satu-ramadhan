{
    "index": "083",
    "verse": {
        "verse_1": "Wailul lil-muṭaffifīn(a).",
        "verse_2": "Allażīna iżaktālū ‘alan-nāsi yastaufūn(a).",
        "verse_3": "Wa iżā kālūhum au wazanūhum yukhsirūn(a).",
        "verse_4": "Alā yaẓunnu ulā'ika annahum mab‘ūṡūn(a).",
        "verse_5": "Liyaumin ‘aẓīm(in).",
        "verse_6": "Yauma yaqūmun-nāsu lirabbil-‘ālamīn(a).",
        "verse_7": "Kallā inna kitābal-fujjāri lafī sijjīn(in).",
        "verse_8": "Wa mā adrāka mā sijjīn(un).",
        "verse_9": "Kitābum marqūm(un).",
        "verse_10": "Wailuy yauma'iżil lil-mukażżibīn(a).",
        "verse_11": "Allażīna yukażżibūna biyaumid-dīn(i).",
        "verse_12": "Wa mā yukażżibu bihī illā kullu mu‘tadin aṡīm(in).",
        "verse_13": "Iżā tutlā ‘alaihi āyātunā qāla asāṭīrul-awwalīn(a).",
        "verse_14": "Kallā bal…rāna ‘alā qulūbihim mā kānū yaksibūn(a).",
        "verse_15": "Kallā innahum ‘ar rabbihim yauma'iżil lamaḥjūbūn(a).",
        "verse_16": "Ṡumma innahum laṣālul-jaḥīm(i). ",
        "verse_17": "Ṡumma yuqālu hāżal-lażī kuntum bihī tukażżibūn(a).",
        "verse_18": "Kallā inna kitābal-abrāri lafī ‘illiyyīn(a).",
        "verse_19": "Wa mā adrāka mā ‘illiyyūn(a).",
        "verse_20": "Kitābum marqūm(un).",
        "verse_21": "Yasyhaduhul-muqarrabūn(a).",
        "verse_22": "Innal-abrāra lafī na‘īm(in).",
        "verse_23": "‘Alal-arā'iki yanẓurūn(a).",
        "verse_24": "Ta‘rifu fī wujūhihim naḍratan na‘īm(i).",
        "verse_25": "Yusqauna mir raḥīqim makhtūm(in).",
        "verse_26": "Khitāmuhū misk(un), wa fī żālika falyatanāfasil-mutanāfisūn(a).",
        "verse_27": "Wa mizājuhū min tasnīm(in).",
        "verse_28": "‘Ainay yasyrabu bihal-muqarrabūn(a).",
        "verse_29": "Innal-lażīna ajramū kānū minal-lażīna āmanū yaḍḥakūn(a).",
        "verse_30": "Wa iżā marrū bihim yatagāmazūn(a).",
        "verse_31": "Wa iżanqalabū ilā ahlihimunqalabū fakihīn(a).",
        "verse_32": "Wa iżā ra'auhum qālū inna hā'ulā'i laḍāllūn(a).",
        "verse_33": "Wa mā ursilū ‘alaihim ḥāfiẓīn(a). ",
        "verse_34": "Fal-yaumal-lażīna āmanū minal kuffāri yaḍḥakūn(a).",
        "verse_35": "‘Alal-arā'iki yanẓurūn(a).",
        "verse_36": "Hal ṡuwwibal-kuffāru mā kānū yaf‘alūn(a)."
    }
}