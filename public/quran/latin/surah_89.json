{
    "index": "089",
    "verse": {
        "verse_1": "Wal-fajr(i).",
        "verse_2": "Wa layālin ‘asyr(in).",
        "verse_3": "Wasy-syaf‘i wal-watr(i).",
        "verse_4": "Wal-laili iżā yasr(i).",
        "verse_5": "Hal fī żālika qasamul liżī ḥijr(in).",
        "verse_6": "Alam tara kaifa fa‘ala rabbuka bi‘ād(in).",
        "verse_7": "Irama żātil-‘imād(i).",
        "verse_8": "Allatī lam yukhlaq miṡluhā fil-bilād(i).",
        "verse_9": "Wa ṡamūdal-lażīna jābuṣ-ṣakhra bil-wād(i).",
        "verse_10": "Wa fir‘auna żil-autād(i). ",
        "verse_11": "Allażīna ṭagau fil-bilād(i).",
        "verse_12": "Fa akṡarū fīhal-fasād(a).",
        "verse_13": "Fa ṣabba ‘alaihim rabbuka sauṭa ‘ażāb(in).",
        "verse_14": "Inna rabbaka labil-mirṣād(i).",
        "verse_15": "Fa ammal-insānu iżā mabtalāhu rabbuhū fa akramahū wa na‘‘amah(ū), fa yaqūlu rabbī akraman(i).",
        "verse_16": "Wa ammā iżā mabtalāhu fa qadara ‘alaihi rizqah(ū), fa yaqūlu rabbī ahānan(i).",
        "verse_17": "Kallā bal lā tukrimūnal-yatīm(a).",
        "verse_18": "Wa lā taḥāḍḍūna ‘alā ṭa‘āmil-miskīn(i).",
        "verse_19": "Wa ta'kulūnat-turāṡa aklal lammā(n).",
        "verse_20": "Wa tuḥibbūnal-māla ḥubban jammā(n).",
        "verse_21": "Kallā iżā dukkatil-arḍu dakkan dakkā(n).",
        "verse_22": "Wa jā'a rabbuka wal-malaku ṣaffan ṣaffā(n).",
        "verse_23": "Wa jī'a yauma'iżim bijahannam(a), yauma'iżiy yatażakkarul-insānu wa annā lahuż-żikrā.",
        "verse_24": "Yaqūlu yā laitanī qaddamtu liḥayātī.",
        "verse_25": "Fa yauma'iżil lā yu‘ażżibu ‘ażābahū aḥad(un).",
        "verse_26": "Wa lā yūṡiqu waṡāqahū aḥad(un).",
        "verse_27": "Yā ayyatuhan-nafsul-muṭma'innah(tu).",
        "verse_28": "Irji‘ī ilā rabbiki rāḍiyatam marḍiyyah(tan).",
        "verse_29": "Fadkhuli fī ‘ibādī.",
        "verse_30": "Wadkhulī jannatī."
    }
}