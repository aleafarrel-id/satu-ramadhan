{
    "index": "091",
    "verse": {
        "verse_1": "Wasy-syamsi wa ḍuḥāhā.",
        "verse_2": "Wal-qamari iżā talāhā.",
        "verse_3": "Wan-nahāri iżā jallāhā.",
        "verse_4": "Wal-laili iżā yagsyāhā.",
        "verse_5": "Was-samā'i wa mā banāhā.",
        "verse_6": "Wal-arḍi wa mā ṭaḥāhā.",
        "verse_7": "Wa nafsiw wa mā sawwāhā.",
        "verse_8": "Fa alhamahā fujūrahā wa taqwāhā.",
        "verse_9": "Qad aflaḥa man zakkāhā.",
        "verse_10": "Wa qad khāba man dassāhā.",
        "verse_11": "Każżabat ṡamūdu biṭagwāhā.",
        "verse_12": "Iżimba‘aṡa asyqāhā.",
        "verse_13": "Fa qāla lahum rasūlullāhi nāqatallāhi wa suqyāhā.",
        "verse_14": "Fa każżabūhu fa ‘aqarūhā fa damdama ‘alaihim rabbuhum biżambihim fa sawwāhā.",
        "verse_15": "Wa lā yakhāfu ‘uqbāhā."
    }
}