{
    "index": "104",
    "verse": {
        "verse_1": "Wailul likulli humazatil-lumazah(tin).",
        "verse_2": "Allażī jama‘a mālaw wa ‘addadah(ū).",
        "verse_3": "Yaḥsabu anna mālahū akhladah(ū).",
        "verse_4": "Kallā layumbażanna fil-ḥuṭamah(ti).",
        "verse_5": "Wa mā adrāka mal-ḥuṭamah(tu).",
        "verse_6": "Nārullāhil-mūqadah(tu).",
        "verse_7": "Allatī taṭṭali‘u ‘alal-af'idah(ti).",
        "verse_8": "Innahā ‘alaihim mu'ṣadah(tun).",
        "verse_9": "Fī ‘amadim mumaddadah(tin)."
    }
}