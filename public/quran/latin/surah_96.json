{
    "index": "096",
    "verse": {
        "verse_1": "Iqra' bismi rabbikal-lażī khalaq(a).",
        "verse_2": "Khalaqal-insāna min ‘alaq(in).",
        "verse_3": "Iqra' wa rabbukal-akram(u).",
        "verse_4": "Allażī ‘allama bil-qalam(i).",
        "verse_5": "‘Allamal-insāna mā lam ya‘lam.",
        "verse_6": "Kallā innal-insāna layaṭgā.",
        "verse_7": "Ar ra'āhustagnā.",
        "verse_8": "Inna ilā rabbikar-ruj‘ā.",
        "verse_9": "Ara'aital-lażī yanhā.",
        "verse_10": "‘Abdan iżā ṣallā.",
        "verse_11": "Ara'aita in kāna ‘alal-hudā.",
        "verse_12": "Au amara bit-taqwā. ",
        "verse_13": "Ara'aita in każżaba wa tawallā.",
        "verse_14": "Alam ya‘lam bi'annallāha yarā.",
        "verse_15": "Kallā la'il lam yantah(i), lanasfa‘am bin-nāṣiyah(ti).",
        "verse_16": "Nāṣiyatin kāżibatin khāṭi'ah(tin).",
        "verse_17": "Falyad‘u nādiyah(ū).",
        "verse_18": "Sanad‘uz-zabāniyah(ta).",
        "verse_19": "Kallā, lā tuṭi‘hu wasjud waqtarib."
    }
}