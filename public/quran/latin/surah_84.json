{
    "index": "084",
    "verse": {
        "verse_1": "Iżas-samā'unsyaqqat.",
        "verse_2": "Wa ażinat lirabbihā wa ḥuqqat.",
        "verse_3": "Wa iẓal-arḍu muddat. ",
        "verse_4": "Wa alqat mā fīhā wa takhallat. ",
        "verse_5": "Wa ażinat lirabbihā wa ḥuqqat. ",
        "verse_6": "Yā ayyuhal-insānu innaka kādiḥun ilā rabbika kadḥan fa mulāqīh(i). ",
        "verse_7": "Fa ammā man ūtiya kitābahū biyamīnih(ī). ",
        "verse_8": "Fa saufa yuḥāsabu ḥisābay yasīrā(n).",
        "verse_9": "Wa yanqalibu ilā ahlihī masrūrā(n).",
        "verse_10": "Wa ammā man ūtiya kitābahū warā'a ẓahrih(ī).",
        "verse_11": "Fa saufa yad‘ū ṡubūrā(n).",
        "verse_12": "Wa yaṣlā sa‘īrā(n).",
        "verse_13": "Innahū kāna fī ahlihī masrūrā(n).",
        "verse_14": "Innahū ẓanna allay yaḥūr(a).",
        "verse_15": "Balā, inna rabbahū kāna bihī baṣīrā(n).",
        "verse_16": "Falā uqsimu bisy-syafaq(i).",
        "verse_17": "Wal-laili wa mā wasaq(a).",
        "verse_18": "Wal-qamari iżattasaq(a).",
        "verse_19": "Latarkabunna ṭabaqan ‘an ṭabaq(in).",
        "verse_20": "Famā lahum lā yu'minūn(a).",
        "verse_21": "Wa iżā quri'a ‘alaihimul-qur'ānu lā yasjudūn(a).",
        "verse_22": "Balil-lażīna kafarū yukażżibūn(a).",
        "verse_23": "Wallāhu a‘lamu bimā yū‘ūn(a).",
        "verse_24": "Fa basysyirhum bi‘ażābin alīm(in).",
        "verse_25": "Illal-lażīna āmanū wa ‘amiluṣ-ṣāliḥāti lahum ajrun gairu mamnūn(in)."
    }
}