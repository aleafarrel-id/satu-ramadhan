{
    "index": "075",
    "verse": {
        "verse_1": "Lā uqsimu biyaumil-qiyāmah(ti).",
        "verse_2": "Wa lā uqsimu bin nafsil-lawwāmah(ti).",
        "verse_3": "Ayaḥsabul-insānu allan najma‘a ‘iẓāmah(ū).",
        "verse_4": "Balā qādirīna ‘alā an nusawwiya banānah(ū).",
        "verse_5": "Bal yurīdul-insānu liyafjura amāmah(ū).",
        "verse_6": "Yas'alu ayyāna yaumul-qiyāmah(ti).",
        "verse_7": "Fa iżā bariqal-baṣar(u).",
        "verse_8": "Wa khasafal-qamar(u).",
        "verse_9": "Wa jumi‘asy-syamsu wal-qamar(u).",
        "verse_10": "Yaqūlul-insānu yauma'iżin ainal-mafarr(u).",
        "verse_11": "Kallā lā wazar(a).",
        "verse_12": "Ilā rabbika yauma'iżinil-mustaqarr(u).",
        "verse_13": "Yunabba'ul-insānu yauma'iżim bimā qaddama wa akhkhar(a).",
        "verse_14": "Balil-insānu ‘alā nafsihī baṣīrah(tun).",
        "verse_15": "Wa lau alqā ma‘āżīrah(ū).",
        "verse_16": "Lā tuḥarrik bihī lisānaka lita‘jala bih(ī).",
        "verse_17": "Inna ‘alainā jam‘ahū wa qur'ānah(ū).",
        "verse_18": "Fa iżā qara'nāhu fattabi‘ qur'ānah(ū).",
        "verse_19": "Ṡumma inna ‘alainā bayānah(ū).",
        "verse_20": "Kallā bal tuḥibbūnal-‘ājilah(ta).",
        "verse_21": "Wa tażarūnal-‘ākhirah(ta).",
        "verse_22": "Wujūhuy yauma'iżin nāḍirah(tun).",
        "verse_23": "Ilā rabbihā nāẓirah(tun).",
        "verse_24": "Wa wujūhuy yauma'iżim bāsirah(tun). ",
        "verse_25": "Taẓunnu ay yuf‘ala bihā fāqirah(tun).",
        "verse_26": "Kallā iżā balagatit-tarāqiy(a).",
        "verse_27": "Wa qīla man…rāq(in).",
        "verse_28": "Wa ẓanna annahul-firāq(u).",
        "verse_29": "Waltaffatis-sāqu bis-sāq(i).",
        "verse_30": "Ilā rabbika yauma'iżinil-masāq(u).",
        "verse_31": "Falā ṣaddaqa wa lā ṣallā.",
        "verse_32": "Wa lākin każżaba wa tawallā.",
        "verse_33": "Ṡumma żahaba ilā ahlihī yatamaṭṭā.",
        "verse_34": "Aulā laka fa'aulā.",
        "verse_35": "Ṡumma aulā laka fa'aulā.",
        "verse_36": "Ayaḥsabul-insānu ay yutraka sudā(n).",
        "verse_37": "Alam yaku nuṭfatam mim maniyyiy yumnā.",
        "verse_38": "Ṡumma kāna ‘alaqatan fa khalaqa fa sawwā.",
        "verse_39": "Fa ja‘ala minhuz-zaujainiż-żakara wal-unṡā.",
        "verse_40": "Alaisa żālika  biqādirin ‘alā ay yuḥyiyal-mautā."
    }
}