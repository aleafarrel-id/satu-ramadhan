{
    "index": "114",
    "verse": {
        "verse_1": "Qul a‘ūżu birabbin-nās(i).",
        "verse_2": "Malikin-nās(i).",
        "verse_3": "Ilāhin-nās(i).",
        "verse_4": "Min syarril-waswāsil-khannās(i).",
        "verse_5": "Allażī yuwaswisu fī ṣudūrin-nās(i).",
        "verse_6": "Minal jinnati wan-nās(i)."
    }
}